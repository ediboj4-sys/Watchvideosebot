<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Taskcoin bot — Watch & Earn</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<script src="https://sad.adsgram.ai/js/sad.min.js"></script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap');

  :root{
    --bg:#0b0f14;
    --panel:#121821;
    --panel-2:#161d28;
    --line:#212b38;
    --text:#eaf0f6;
    --muted:#8a96a3;
    --ad:#f2a93b;
    --ad-deep:#8a5c14;
    --task:#22c3a6;
    --task-deep:#0e5c4f;
    --refer:#6d8cff;
    --warn-bg:#241a08;
    --warn-line:#5c4416;
  }

  *{box-sizing:border-box; margin:0; padding:0;}
  html,body{height:100%;}
  body{
    background:
      radial-gradient(ellipse 900px 500px at 15% -5%, rgba(109,140,255,0.10), transparent 60%),
      radial-gradient(ellipse 700px 500px at 100% 10%, rgba(34,195,166,0.08), transparent 55%),
      var(--bg);
    color:var(--text);
    font-family:'Inter', Arial, sans-serif;
    padding:16px 16px 100px;
    min-height:100vh;
  }

  .wrap{max-width:520px; margin:0 auto;}

  .topline{display:flex; align-items:center; justify-content:space-between; margin-bottom:18px;}
  .brand{display:flex; align-items:center; gap:10px;}
  .brand-icon{width:36px; height:36px; border-radius:10px; background:linear-gradient(135deg, var(--refer), #3a54c9); display:flex; align-items:center; justify-content:center; font-size:18px;}
  .brand-name{font-family:'Sora',sans-serif; font-weight:700; font-size:15px;}
  .brand-sub{font-size:11px; color:var(--muted); letter-spacing:.04em; text-transform:uppercase;}
  .userchip{display:flex; align-items:center; gap:8px; background:var(--panel); border:1px solid var(--line); padding:6px 12px 6px 6px; border-radius:20px; font-size:12px;}
  .userchip .av{width:22px;height:22px;border-radius:50%;background:linear-gradient(135deg,#3a4a5c,#222b36);}

  .info-badge{display:flex; align-items:flex-start; gap:8px; background:var(--warn-bg); border:1px solid var(--warn-line); color:#f2c569; font-size:11.5px; font-weight:500; line-height:1.5; padding:10px 12px; border-radius:10px; margin-bottom:16px;}

  .hero h1{font-family:'Sora',sans-serif; font-size:26px; font-weight:800; letter-spacing:-.01em;}
  .hero p{color:var(--muted); font-size:13.5px; margin-top:4px;}

  .balance-row{display:flex; align-items:baseline; gap:8px; margin:16px 0 20px; background:var(--panel); border:1px solid var(--line); border-radius:16px; padding:16px 18px;}
  .balance-num{font-family:'Sora',sans-serif; font-size:32px; font-weight:800;}
  .balance-unit{color:var(--muted); font-size:13px; font-weight:600;}
  .balance-side{margin-left:auto; text-align:right; font-size:11.5px; color:var(--muted);}

  .grid2{display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px;}
  .earn-card{border-radius:18px; padding:16px; position:relative; overflow:hidden; border:1px solid var(--line);}
  .earn-card.ad{background:linear-gradient(160deg, var(--ad) 0%, var(--ad-deep) 130%); color:#241703;}
  .earn-card.task{background:linear-gradient(160deg, var(--task) 0%, var(--task-deep) 130%); color:#04211c;}
  .earn-card .eyebrow{font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; opacity:.75;}
  .earn-card .amount{font-family:'Sora',sans-serif; font-size:24px; font-weight:800; margin-top:4px;}
  .earn-card .cap{font-size:11.5px; opacity:.8; margin-top:2px;}
  .mini-progress{height:6px; border-radius:10px; background:rgba(0,0,0,0.18); margin-top:12px; overflow:hidden;}
  .mini-progress > div{height:100%; background:rgba(0,0,0,0.55); width:0%; transition:width .3s;}
  .earn-btn{width:100%; margin-top:12px; padding:10px; border:none; border-radius:12px; background:rgba(0,0,0,0.82); color:#fff; font-weight:700; font-size:13px; cursor:pointer;}
  .earn-btn:disabled{opacity:.55; cursor:not-allowed;}
  .earn-btn:active:not(:disabled){transform:scale(.97);}

  .disclaimer{background:var(--warn-bg); border:1px solid var(--warn-line); border-radius:14px; padding:14px 16px; margin-bottom:16px; font-size:12.5px; line-height:1.5; color:#e8d3a0;}
  .disclaimer b{color:#f2c569;}

  .section{background:var(--panel); border:1px solid var(--line); border-radius:16px; padding:16px; margin-bottom:16px;}
  .section h2{font-family:'Sora',sans-serif; font-size:14.5px; font-weight:700; margin-bottom:12px;}
  .rules{display:grid; grid-template-columns:1fr 1fr; gap:14px;}
  .rules .col h3{font-size:12px; color:var(--muted); font-weight:600; margin-bottom:8px;}
  .rules .row{display:flex; justify-content:space-between; font-size:13px; padding:4px 0;}
  .rules .row span:last-child{font-weight:700;}

  .live-note{text-align:center; font-size:12px; color:var(--muted); margin:-4px 0 16px;}

  .refer-box{display:flex; align-items:center; gap:12px; margin-bottom:10px;}
  .refer-icon{width:44px;height:44px;border-radius:12px; background:linear-gradient(135deg, var(--refer), #3a54c9); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;}
  .refer-copy{flex:1;}
  .refer-copy .t{font-weight:700; font-size:14px;}
  .refer-copy .s{font-size:12px; color:var(--muted); margin-top:2px;}
  .refer-link-row{display:flex; gap:8px; margin-top:10px;}
  .refer-link-row input{flex:1; background:var(--panel-2); border:1px solid var(--line); color:var(--muted); padding:10px 12px; border-radius:10px; font-size:12px;}
  .refer-link-row button{background:var(--refer); color:#fff; border:none; padding:0 16px; border-radius:10px; font-weight:700; font-size:12.5px; cursor:pointer;}

  .wallet-hero{background:var(--panel); border:1px solid var(--line); border-radius:18px; padding:20px; text-align:center; margin-bottom:16px;}
  .wallet-hero .lbl{font-size:12px; color:var(--muted);}
  .wallet-hero .num{font-family:'Sora',sans-serif; font-size:38px; font-weight:800; margin-top:6px;}
  .wallet-hero .conv{font-size:11.5px; color:var(--muted); margin-top:6px;}

  .form-field{margin-top:10px;}
  .form-field label{font-size:11.5px; color:var(--muted); display:block; margin-bottom:6px;}
  .form-field select, .form-field input{
    width:100%; background:var(--panel-2); border:1px solid var(--line); color:var(--text);
    padding:11px 12px; border-radius:10px; font-size:13px;
  }
  .withdraw-btn{width:100%; margin-top:14px; padding:12px; border:none; border-radius:12px; background:linear-gradient(90deg,var(--refer),#3a54c9); color:#fff; font-weight:700; font-size:13.5px; cursor:pointer;}
  .withdraw-btn:disabled{opacity:.5; cursor:not-allowed;}
  .withdraw-note{font-size:11.5px; color:var(--muted); margin-top:10px; line-height:1.5;}

  .txn{display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid var(--line); font-size:13px;}
  .txn:last-child{border-bottom:none;}
  .txn .t{font-weight:600;}
  .txn .d{font-size:11.5px; color:var(--muted); margin-top:2px;}
  .txn .amt{color:var(--task); font-weight:700;}
  .txn .amt.neg{color:#ff6b6b;}

  .task-item{display:flex; align-items:center; justify-content:space-between; padding:12px 0; border-bottom:1px solid var(--line);}
  .task-item:last-child{border-bottom:none;}
  .task-item .t{font-size:13.5px; font-weight:600;}
  .task-item .s{font-size:11.5px; color:var(--muted); margin-top:2px;}
  .task-chip{background:var(--task); color:#04211c; font-weight:700; font-size:12px; padding:7px 14px; border-radius:10px; border:none; cursor:pointer; white-space:nowrap;}
  .task-chip.done{background:#2a3542; color:var(--muted); cursor:default;}
  .task-chip:disabled{opacity:.6; cursor:not-allowed;}

  .page{display:none;}
  .page.active{display:block;}

  .nav{position:fixed; left:0; right:0; bottom:0; background:rgba(11,15,20,0.92); backdrop-filter:blur(10px); border-top:1px solid var(--line); display:flex; justify-content:space-around; padding:10px 6px 14px;}
  .nav button{background:none; border:none; color:var(--muted); font-size:11px; font-weight:600; display:flex; flex-direction:column; align-items:center; gap:4px; cursor:pointer;}
  .nav button .ic{font-size:19px;}
  .nav button.active{color:var(--text);}
  .nav button.active .ic{filter:drop-shadow(0 0 6px rgba(109,140,255,0.6));}

  .toast{position:fixed; left:50%; bottom:96px; transform:translateX(-50%) translateY(20px); background:#1a2230; border:1px solid var(--line); color:var(--text); padding:12px 18px; border-radius:12px; font-size:13px; font-weight:600; opacity:0; pointer-events:none; transition:all .25s ease; z-index:999; box-shadow:0 10px 30px rgba(0,0,0,0.4); max-width:88%; text-align:center;}
  .toast.show{opacity:1; transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>

<div class="wrap">

  <div class="topline">
    <div class="brand">
      <div class="brand-icon">📨</div>
      <div><div class="brand-name">TaskHub</div><div class="brand-sub">Mini App</div></div>
    </div>
    <div class="userchip"><div class="av"></div><span id="userIdChip">Guest</span></div>
  </div>

  <div class="info-badge">🕓 Withdrawal requests are reviewed and paid out manually — they are not instant. Minimum withdrawal is 10,000 pts.</div>

  <!-- ============ HOME PAGE ============ -->
  <div id="home-page" class="page active">
    <div class="hero">
      <h1>Earn More</h1>
      <p>Tap a card to start earning. Nothing here is required.</p>
    </div>

    <div class="balance-row">
      <div class="balance-num" id="balanceNum">0</div>
      <div class="balance-unit">pts</div>
      <div class="balance-side">Min withdrawal: 10,000 pts</div>
    </div>

    <div class="grid2">
      <div class="earn-card ad">
        <div class="eyebrow">Rewarded Ad</div>
        <div class="amount">+10 pts</div>
        <div class="cap" id="adDailyCap">Daily 0 / 300</div>
        <div class="mini-progress"><div id="adProgressFill"></div></div>
        <button class="earn-btn" id="watchAdBtn">▶ Watch Ad</button>
      </div>
      <div class="earn-card task">
        <div class="eyebrow">Tasks</div>
        <div class="amount">+30 pts</div>
        <div class="cap" id="taskDailyCap">Daily 0 / 150</div>
        <div class="mini-progress"><div id="taskProgressFill"></div></div>
        <button class="earn-btn" id="goTasksBtn">Go →</button>
      </div>
    </div>

    <div class="disclaimer">
      <b>Optional, always.</b> Watching ads and completing tasks is 100% optional. You are never required
      to watch an ad or finish a task to use TaskHub, and no content or feature is locked behind an ad view.
    </div>

    <div class="section">
      <h2>Earning rules</h2>
      <div class="rules">
        <div class="col">
          <h3>REWARDED AD</h3>
          <div class="row"><span>Cooldown</span><span>60 min</span></div>
          <div class="row"><span>Max / day</span><span>300 pts</span></div>
        </div>
        <div class="col">
          <h3>OPTIONAL TASK</h3>
          <div class="row"><span>Cooldown</span><span>60 sec</span></div>
          <div class="row"><span>Max / day</span><span>150 pts</span></div>
        </div>
      </div>
    </div>

    <div class="live-note" id="liveNote">15 live tasks right now · watch ads &amp; earn</div>
  </div>

  <!-- ============ TASKS PAGE ============ -->
  <div id="tasks-page" class="page">
    <div class="hero">
      <h1>Tasks</h1>
      <p>Optional actions. Complete any of these when you feel like it.</p>
    </div>

    <div class="section">
      <h2>🎯 Available today</h2>
      <div class="task-item">
        <div><div class="t">Visit Twitter / X</div><div class="s">Follow the project account</div></div>
        <button class="task-chip" id="task-1" onclick="completeTask(1,30)">+30 pts</button>
      </div>
      <div class="task-item">
        <div><div class="t">Share on Telegram</div><div class="s">Share to 5 chats</div></div>
        <button class="task-chip" id="task-2" onclick="completeTask(2,50)">+50 pts</button>
      </div>
      <div class="task-item">
        <div><div class="t">Join partner channel</div><div class="s">Optional community task</div></div>
        <button class="task-chip" id="task-3" onclick="completeTask(3,40)">+40 pts</button>
      </div>
      <div class="task-item">
        <div><div class="t">Watch a bonus ad</div><div class="s">Optional — same rules apply</div></div>
        <button class="task-chip" id="task-ad" onclick="watchBonusAdTask()">+30 pts</button>
      </div>
    </div>

    <div class="disclaimer">
      <b>No pressure.</b> Skipping every task on this page has zero effect on your account, balance,
      or access to any part of the app.
    </div>
  </div>

  <!-- ============ REFERRAL PAGE ============ -->
  <div id="refer-page" class="page">
    <div class="hero">
      <h1>Refer friends</h1>
      <p>Share your link — earn points for every friend who joins.</p>
    </div>

    <div class="section">
      <div class="refer-box">
        <div class="refer-icon">🤝</div>
        <div class="refer-copy">
          <div class="t">+20 pts per referral</div>
          <div class="s">Credited once your friend opens the app</div>
        </div>
      </div>
      <div class="refer-link-row">
        <input id="referLinkInput" readonly value="https://t.me/TaskHubBot?start=ref_000000" />
        <button id="copyReferBtn">Copy</button>
      </div>
    </div>

    <div class="section">
      <h2>Your referrals</h2>
      <div class="task-item">
        <div><div class="t" id="referCount">0 friends joined</div><div class="s">Track your invites here</div></div>
        <div class="amt" style="color:var(--refer); font-weight:700;" id="referEarned">+0 pts</div>
      </div>
    </div>
  </div>

  <!-- ============ WALLET PAGE ============ -->
  <div id="wallet-page" class="page">
    <div class="hero">
      <h1>Wallet</h1>
      <p>Your points balance and withdrawal requests.</p>
    </div>

    <div class="wallet-hero">
      <div class="lbl">Total balance</div>
      <div class="num"><span id="walletBalance">0</span> pts</div>
      <div class="conv">Minimum withdrawal: 10,000 pts</div>
    </div>

    <div class="section">
      <h2>💳 Withdraw</h2>
      <div class="form-field">
        <label>Payment method</label>
        <select id="withdrawMethod">
          <option>Litecoin</option>
          <option>Binance Pay</option>
          <option>FaucetPay</option>
          <option>USDT</option>
        </select>
      </div>
      <div class="form-field">
        <label>Wallet / account address</label>
        <input id="withdrawAddress" placeholder="Paste your address" />
      </div>
      <div class="form-field">
        <label>Amount (pts)</label>
        <input id="withdrawAmount" type="number" min="10000" step="1" placeholder="Minimum 10,000" />
      </div>
      <button class="withdraw-btn" id="withdrawBtn">Request Withdrawal</button>
      <div class="withdraw-note">
        Requests are sent for manual review. You'll be notified once it's processed — this isn't instant.
      </div>
    </div>

    <div class="section">
      <h2>📝 Activity</h2>
      <div id="txnList">
        <div class="txn"><div><div class="t">No activity yet</div><div class="d">Watch an ad or complete a task to get started</div></div></div>
      </div>
    </div>
  </div>

</div>

<div class="toast" id="toast"></div>

<div class="nav">
  <button class="nav-btn active" id="nav-home" onclick="showPage('home')"><span class="ic">🏠</span>Home</button>
  <button class="nav-btn" id="nav-tasks" onclick="showPage('tasks')"><span class="ic">✅</span>Tasks</button>
  <button class="nav-btn" id="nav-refer" onclick="showPage('refer')"><span class="ic">🤝</span>Refer</button>
  <button class="nav-btn" id="nav-wallet" onclick="showPage('wallet')"><span class="ic">💰</span>Wallet</button>
</div>

<script>
const tg = window.Telegram?.WebApp;
try{ tg?.expand?.(); }catch(e){}

/* =========================================================================
   CONFIG — fill these in before going live
   ========================================================================= */
// Adsgram block IDs — paste your real IDs from the Adsgram dashboard.
// Each block ID maps to ONE placement so Adsgram's reporting stays accurate
// per-placement (reward ad vs. the in-task bonus ad are tracked separately).
const ADSGRAM_REWARD_BLOCK_ID = '37622'; // used by the Home "Watch Ad" card
const ADSGRAM_TASK_BLOCK_ID   = 'int-37625';   // used by the Tasks "bonus ad" row only

// Telegram bot used to forward withdrawal requests to you for manual payout.
// NOTE: this token is embedded in client-side code once deployed to GitHub
// Pages, so anyone can view-source and read it. See the assistant's message
// for why that's a real risk and what to do instead.
const TELEGRAM_BOT_TOKEN = 'YOUR_BOT_TOKEN';
const ADMIN_CHAT_ID = '23674574';

/* ---------------- STATE ---------------- */
let balance         = Number(localStorage.getItem('th_balance') || '0');
let adDailyCount     = Number(localStorage.getItem('th_adDailyCount') || '0');
let adDailyDate      = localStorage.getItem('th_adDailyDate') || '';
let taskDailyCount   = Number(localStorage.getItem('th_taskDailyCount') || '0');
let taskDailyDate    = localStorage.getItem('th_taskDailyDate') || '';
let lastAdTime       = Number(localStorage.getItem('th_lastAdTime') || '0');
let completedTasks   = JSON.parse(localStorage.getItem('th_completedTasks') || '[]');
let referCount       = Number(localStorage.getItem('th_referCount') || '0');
let referEarned      = Number(localStorage.getItem('th_referEarned') || '0');
let activity         = JSON.parse(localStorage.getItem('th_activity') || '[]');

const AD_COOLDOWN_MS   = 60 * 60 * 1000;   // 60 min
const AD_MAX_PER_DAY   = 300;              // pts/day cap
const TASK_MAX_PER_DAY = 150;              // pts/day cap
const AD_REWARD        = 10;               // pts per rewarded ad
const REFERRAL_REWARD  = 20;               // pts per referral
const MIN_WITHDRAWAL   = 10000;            // pts

function todayStr(){ return new Date().toDateString(); }
if (adDailyDate !== todayStr()) { adDailyCount = 0; adDailyDate = todayStr(); }
if (taskDailyDate !== todayStr()) { taskDailyCount = 0; taskDailyDate = todayStr(); }

/* Adsgram init — each unit points at its own block ID, initiated only on click below */
let rewardAd, taskAd;
window.addEventListener('load', () => {
  if (typeof Adsgram !== 'undefined') {
    rewardAd = Adsgram.init({ blockId: ADSGRAM_REWARD_BLOCK_ID });
    taskAd   = Adsgram.init({ blockId: ADSGRAM_TASK_BLOCK_ID });
  }
});

/* ---------------- PERSIST + RENDER ---------------- */
function persist(){
  localStorage.setItem('th_balance', balance);
  localStorage.setItem('th_adDailyCount', adDailyCount);
  localStorage.setItem('th_adDailyDate', adDailyDate);
  localStorage.setItem('th_taskDailyCount', taskDailyCount);
  localStorage.setItem('th_taskDailyDate', taskDailyDate);
  localStorage.setItem('th_lastAdTime', lastAdTime);
  localStorage.setItem('th_completedTasks', JSON.stringify(completedTasks));
  localStorage.setItem('th_referCount', referCount);
  localStorage.setItem('th_referEarned', referEarned);
  localStorage.setItem('th_activity', JSON.stringify(activity.slice(0,20)));
}

function addActivity(title, pts){
  activity.unshift({ title, pts, when: new Date().toLocaleString() });
  persist();
  renderActivity();
}

function renderActivity(){
  const list = document.getElementById('txnList');
  if (!activity.length){
    list.innerHTML = `<div class="txn"><div><div class="t">No activity yet</div><div class="d">Watch an ad or complete a task to get started</div></div></div>`;
    return;
  }
  list.innerHTML = activity.slice(0,10).map(a => `
    <div class="txn">
      <div><div class="t">${a.title}</div><div class="d">${a.when}</div></div>
      <div class="amt ${a.pts < 0 ? 'neg' : ''}">${a.pts > 0 ? '+' : ''}${a.pts} pts</div>
    </div>
  `).join('');
}

function render(){
  document.getElementById('balanceNum').innerText = balance;
  document.getElementById('walletBalance').innerText = balance;

  document.getElementById('adDailyCap').innerText = `Daily ${adDailyCount} / ${AD_MAX_PER_DAY}`;
  document.getElementById('adProgressFill').style.width = Math.min(100, (adDailyCount/AD_MAX_PER_DAY)*100) + '%';

  document.getElementById('taskDailyCap').innerText = `Daily ${taskDailyCount} / ${TASK_MAX_PER_DAY}`;
  document.getElementById('taskProgressFill').style.width = Math.min(100, (taskDailyCount/TASK_MAX_PER_DAY)*100) + '%';

  document.getElementById('referCount').innerText = `${referCount} friends joined`;
  document.getElementById('referEarned').innerText = `+${referEarned} pts`;

  updateAdButton();
  updateTaskButtons();
  updateWithdrawButton();
  persist();
}

function updateAdButton(){
  const btn = document.getElementById('watchAdBtn');
  const now = Date.now();
  const sinceLast = now - lastAdTime;
  const capped = adDailyCount >= AD_MAX_PER_DAY;

  if (capped){
    btn.disabled = true;
    btn.innerText = 'Daily cap reached';
  } else if (sinceLast < AD_COOLDOWN_MS){
    btn.disabled = true;
    const mins = Math.ceil((AD_COOLDOWN_MS - sinceLast)/60000);
    btn.innerText = `Next ad in ${mins} min`;
  } else {
    btn.disabled = false;
    btn.innerText = '▶ Watch Ad';
  }
}

function updateTaskButtons(){
  [1,2,3].forEach(id => {
    const btn = document.getElementById(`task-${id}`);
    if (completedTasks.includes(`task-${id}`)){
      btn.classList.add('done');
      btn.innerText = '✅ Done';
      btn.disabled = true;
    }
  });
  const adTaskBtn = document.getElementById('task-ad');
  if (completedTasks.includes('task-ad')){
    adTaskBtn.classList.add('done');
    adTaskBtn.innerText = '✅ Done';
    adTaskBtn.disabled = true;
  }
}

function updateWithdrawButton(){
  const btn = document.getElementById('withdrawBtn');
  btn.disabled = balance < MIN_WITHDRAWAL;
  btn.innerText = balance < MIN_WITHDRAWAL
    ? `Need ${MIN_WITHDRAWAL - balance} more pts`
    : 'Request Withdrawal';
}

/* ---------------- TOAST ---------------- */
let toastTimer;
function toast(msg){
  const el = document.getElementById('toast');
  el.innerText = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2600);
}

/* ---------------- EARNING ACTIONS ---------------- */
function grantAdReward(){
  if (adDailyCount >= AD_MAX_PER_DAY) { toast('Daily ad cap reached'); return; }
  balance += AD_REWARD;
  adDailyCount += AD_REWARD;
  lastAdTime = Date.now();
  addActivity('Rewarded ad watched', AD_REWARD);
  toast(`+${AD_REWARD} pts — thanks for watching!`);
  render();
}

document.getElementById('watchAdBtn').addEventListener('click', () => {
  if (!rewardAd){
    toast('Ad not ready — try again shortly');
    return;
  }
  rewardAd.show()
    .then(() => grantAdReward())
    .catch(() => toast('Ad was closed early — no reward given'));
});

function completeTask(id, reward){
  const key = `task-${id}`;
  if (completedTasks.includes(key)) { toast('Already completed'); return; }
  completedTasks.push(key);
  taskDailyCount += reward;
  balance += reward;
  addActivity(`Task completed (#${id})`, reward);
  toast(`+${reward} pts — task complete!`);
  render();
}

function watchBonusAdTask(){
  if (completedTasks.includes('task-ad')) { toast('Already completed'); return; }
  const reward = 30;
  const finish = () => {
    completedTasks.push('task-ad');
    taskDailyCount += reward;
    balance += reward;
    addActivity('Bonus ad task', reward);
    toast(`+${reward} pts — bonus ad complete!`);
    render();
  };
  if (taskAd){
    taskAd.show().then(finish).catch(() => toast('Ad was closed early — no reward given'));
  } else {
    toast('Ad not ready — try again shortly');
  }
}

document.getElementById('goTasksBtn').addEventListener('click', () => showPage('tasks'));

document.getElementById('copyReferBtn').addEventListener('click', () => {
  const input = document.getElementById('referLinkInput');
  navigator.clipboard?.writeText(input.value).then(() => toast('Referral link copied'));
});

/* ---------------- WITHDRAWAL ---------------- */
async function sendWithdrawalToTelegram(details){
  const text =
`💸 New withdrawal request
User: ${details.userId}
Method: ${details.method}
Address: ${details.address}
Amount: ${details.amount} pts
Requested: ${details.when}`;

  const url = `https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`;
  const res = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ chat_id: ADMIN_CHAT_ID, text })
  });
  if (!res.ok) throw new Error('Telegram forward failed');
  return res.json();
}

document.getElementById('withdrawBtn').addEventListener('click', async () => {
  const method  = document.getElementById('withdrawMethod').value;
  const address = document.getElementById('withdrawAddress').value.trim();
  const amount  = parseInt(document.getElementById('withdrawAmount').value, 10);

  if (!address) { toast('Enter your wallet / account address'); return; }
  if (!amount || amount < MIN_WITHDRAWAL) { toast(`Minimum withdrawal is ${MIN_WITHDRAWAL} pts`); return; }
  if (amount > balance) { toast('Not enough points'); return; }

  const btn = document.getElementById('withdrawBtn');
  btn.disabled = true;
  btn.innerText = 'Sending request…';

  const details = {
    userId: tg?.initDataUnsafe?.user?.id || 'unknown (no Telegram context)',
    method, address, amount,
    when: new Date().toLocaleString()
  };

  try{
    await sendWithdrawalToTelegram(details);
    balance -= amount;
    addActivity(`Withdrawal requested (${method})`, -amount);
    toast('Request sent — you\u2019ll be paid after manual review');
    document.getElementById('withdrawAddress').value = '';
    document.getElementById('withdrawAmount').value = '';
    render();
  } catch(e){
    toast('Could not send request — try again later');
    console.error(e);
  } finally {
    updateWithdrawButton();
  }
});

/* ---------------- NAV ---------------- */
function showPage(name){
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav button').forEach(b => b.classList.remove('active'));
  document.getElementById(`${name}-page`).classList.add('active');
  document.getElementById(`nav-${name}`).classList.add('active');
}

/* ---------------- INIT ---------------- */
if (tg?.initDataUnsafe?.user?.id) {
  document.getElementById('userIdChip').innerText = 'id ' + tg.initDataUnsafe.user.id;
}
render();
renderActivity();
setInterval(updateAdButton, 15000);
</script>

</body>
</html>
